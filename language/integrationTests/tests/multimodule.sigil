λmain()=>Unit=()

λprojectConfig()=>String="{\"layout\":{\"src\":\"src\",\"tests\":\"tests\",\"out\":\".local\"}}"

λrunProject(root:String,target:String)=>!Process String={
  l result=(§process.run(•support.sigilIn(["run",target],root)):§process.ProcessResult);
  •support.combinedOutput(result)
}

λwriteProjectFile(content:String,path:String,root:String)=>!Fs Unit=§file.writeText(content,§path.join(root,path))

test "multimodule simple import runs" =>!Clock!Fs!Process {
  l root=(•support.uniqueRepoTempDir("multimodule"):String);
  l _=(§file.makeDirs(§path.join(root,"src")):Unit);
  l _=(writeProjectFile(projectConfig(),"sigil.json",root):Unit);
  l _=(writeProjectFile("λdouble(x:Int)=>Int=x*2\n\nλtriple(x:Int)=>Int=x*3\n","src/utils.lib.sigil",root):Unit);
  l _=(writeProjectFile("i •utils\n\nλmain()=>Int=•utils.double(21)\n","src/main.sigil",root):Unit);
  l output=(runProject(root,"src/main.sigil"):String);
  l _=(§file.removeTree(root):Unit);
  §string.indexOf(output,"42")≥0=true
}

test "multimodule multiple imports run" =>!Clock!Fs!Process {
  l root=(•support.uniqueRepoTempDir("multimodule"):String);
  l _=(§file.makeDirs(§path.join(root,"src")):Unit);
  l _=(writeProjectFile(projectConfig(),"sigil.json",root):Unit);
  l _=(writeProjectFile("λdouble(x:Int)=>Int=x*2\n\nλtriple(x:Int)=>Int=x*3\n","src/utils.lib.sigil",root):Unit);
  l _=(writeProjectFile("λadd(x:Int,y:Int)=>Int=x+y\n\nλsubtract(x:Int,y:Int)=>Int=x-y\n","src/math.lib.sigil",root):Unit);
  l _=(writeProjectFile("i •math\n\ni •utils\n\nλmain()=>Int=•math.add(•utils.double(10),•utils.triple(5))\n","src/calc.sigil",root):Unit);
  l output=(runProject(root,"src/calc.sigil"):String);
  l _=(§file.removeTree(root):Unit);
  §string.indexOf(output,"35")≥0=true
}

test "multimodule transitive dependency runs" =>!Clock!Fs!Process {
  l root=(•support.uniqueRepoTempDir("multimodule"):String);
  l _=(§file.makeDirs(§path.join(root,"src")):Unit);
  l _=(writeProjectFile(projectConfig(),"sigil.json",root):Unit);
  l _=(writeProjectFile("λincrement(x:Int)=>Int=x+1\n","src/base.lib.sigil",root):Unit);
  l _=(writeProjectFile("i •base\n\nλaddTwo(x:Int)=>Int=•base.increment(•base.increment(x))\n","src/derived.lib.sigil",root):Unit);
  l _=(writeProjectFile("i •derived\n\nλmain()=>Int=•derived.addTwo(5)\n","src/app.sigil",root):Unit);
  l output=(runProject(root,"src/app.sigil"):String);
  l _=(§file.removeTree(root):Unit);
  §string.indexOf(output,"7")≥0=true
}
