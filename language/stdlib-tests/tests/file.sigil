test "file remove removes a file" â†’!IO {
  l dir=("/tmp/sigil-stdlib-file-delete":String);
  l filePath=(stdlibâ‹…path.join(dir,"sample.txt"):String);
  l _=(stdlibâ‹…file.removeTree(dir):Unit);
  l _=(stdlibâ‹…file.makeDirs(dir):Unit);
  l _=(stdlibâ‹…file.writeText("hello",filePath):Unit);
  l _=(stdlibâ‹…file.remove(filePath):Unit);
  stdlibâ‹…file.exists(filePath)=false
}

test "file removeTree removes nested output" â†’!IO {
