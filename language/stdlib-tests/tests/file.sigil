test "file readText and appendText preserve utf8 content" â†’!IO {
  l dir=("/tmp/sigil-stdlib-file-read-write":String);
  l filePath=(stdlibâ‹…path.join(dir,"sample.txt"):String);
  l _=(stdlibâ‹…file.removeTree(dir):Unit);
