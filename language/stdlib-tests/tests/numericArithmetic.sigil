i stdlib::numeric

λmain()=>Unit=()

test "numeric.abs returns magnitude" {
  stdlib::numeric.abs(-5)=5 and stdlib::numeric.abs(0)=0 and stdlib::numeric.abs(7)=7
}

test "numeric.divmod returns quotient and remainder" {
  stdlib::numeric.divmod(17,5)={quotient:3,remainder:2} and stdlib::numeric.divmod(-17,5)={quotient:-4,remainder:3}
}

test "numeric.lcm handles signs and zero" {
  stdlib::numeric.lcm(6,8)=24 and stdlib::numeric.lcm(-6,8)=24 and stdlib::numeric.lcm(0,7)=0
}

test "numeric.mod uses non-negative remainder" {
  stdlib::numeric.mod(17,5)=2 and stdlib::numeric.mod(-17,5)=3 and stdlib::numeric.mod(17,-5)=2
}

test "numeric.sign returns canonical sign" {
  stdlib::numeric.sign(-8)=-1 and stdlib::numeric.sign(0)=0 and stdlib::numeric.sign(12)=1
}
