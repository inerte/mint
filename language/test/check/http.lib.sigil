i stdlib::topology

i test::observe::http

i world::http

λcalled(entry:world::http.HttpEntry)=>Bool=test::observe::http.callCount(entry)>0

λcalledNTimes(count:Int,entry:world::http.HttpEntry)=>Bool=test::observe::http.callCount(entry)=count

λcalledOnce(entry:world::http.HttpEntry)=>Bool=calledNTimes(1,entry)

λlastPathIs(entry:world::http.HttpEntry,expected:String)=>Bool match test::observe::http.lastPath(entry){
  Some(actual)=>actual=expected|
  None()=>false
}
