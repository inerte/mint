t ProcessEntry=DenyProcess()|FixtureProcess([ProcessRule])|RealProcess()

t ProcessRule={argv:[String],cwd:Option[String],result:§process.ProcessResult}

λdeny()=>ProcessEntry=DenyProcess()

λfixture(rules:[ProcessRule])=>ProcessEntry=FixtureProcess(rules)

λreal()=>ProcessEntry=RealProcess()

λrule(argv:[String],cwd:Option[String],result:§process.ProcessResult)=>ProcessRule={argv:argv,cwd:cwd,result:result}
