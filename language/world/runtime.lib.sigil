  random:†random.RandomEntry,
  stream:†stream.StreamEntry,
  tcp:[†tcp.TcpEntry],
  timer:†timer.TimerEntry
}

λwithFsRoots(fsRoots:[†fs.FsRootEntry],world:World)=>World={
  clock:world.clock,
  fs:world.fs,
  fsRoots:fsRoots,
  http:world.http,
