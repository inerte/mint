t World={
  clock:†clock.ClockEntry,
  fs:†fs.FsEntry,
  fsRoots:[†fs.FsRootEntry],
  http:[†http.HttpEntry],
  log:†log.LogEntry,
  logSinks:[†log.LogSinkEntry],
  process:†process.ProcessEntry,
  processHandles:[†process.ProcessHandleEntry],
