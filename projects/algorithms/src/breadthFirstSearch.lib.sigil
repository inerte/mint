λbfsLoop(graph:•graphTypes.Graph,queue:[Int],visited:[Int])=>[Int] match queue{
  []=>visited|
  [head,.tail]=>match §list.contains(head,visited){
    true=>bfsLoop(graph,tail,visited)|
    false=>bfsLoop(graph,tail⧺•graphHelpers.neighborsOf(graph,head),visited⧺[head])
  }
}

λbreadthFirstSearch(graph:•graphTypes.Graph,start:Int)=>[Int] match •graphHelpers.hasVertex(graph,start){
  true=>bfsLoop(graph,[start],[])|
  false=>[]
}
