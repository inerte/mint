t Bucket={count:Int,value:Int}

i core::map

Î»buckets(histogram:{Intâ†¦Int})=>[Bucket]=core::map.entries(histogram) map (Î»(entry:core::map.Entry[Int,Int])=>Bucket={count:entry.value,value:entry.key})

Î»histogram(xs:[Int])=>{Intâ†¦Int}=xs reduce increment from (core::map.empty():{Intâ†¦Int})

Î»increment(histogram:{Intâ†¦Int},value:Int)=>{Intâ†¦Int} match core::map.get(value,histogram){
  Some(count)=>core::map.insert(value,histogram,count+1)|
  None()=>core::map.insert(value,histogram,1)
}
