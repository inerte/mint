őĽinsert_sorted(item:‚Ą§,xs:[‚Ą§])‚Üí[‚Ą§] match xs{
  []‚Üí[item]|
  [head,.tail]‚Üímatch item‚Č§head{
    true‚Üí[item,head]‚ßļtail|
    false‚Üí[head]‚ßļinsert_sorted(item,tail)
  }
}

őĽinsertion_sort(xs:[‚Ą§])‚Üí[‚Ą§] match xs{
  []‚Üí[]|
  [head,.tail]‚Üíinsert_sorted(head,insertion_sort(tail))
}
