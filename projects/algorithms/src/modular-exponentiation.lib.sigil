Œªmod_pow(base:‚Ñ§,exponent:‚Ñ§,modulus:‚Ñ§)‚Üí‚Ñ§ match modulus=1{
  true‚Üí0|
  false‚Üímatch exponent=0{
    true‚Üí1%modulus|
    false‚Üímatch exponent%2=0{
      true‚Üí{
        l half=(mod_pow(base,exponent/2,modulus):‚Ñ§);
        (half*half)%modulus
      }|
      false‚Üí(((base%modulus)*mod_pow(base,exponent-1,modulus))%modulus)
    }
  }
}
