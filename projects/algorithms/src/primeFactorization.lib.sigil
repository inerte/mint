i stdlib::list

i stdlib::numeric

λdivisors(n:Int)=>[Int]=stdlib::numeric.range(2,n) filter (λ(divisor:Int)=>Bool=n%divisor=0)

λprimeFactors(n:Int)=>[Int] match n≤1{
  true=>[]|
  false=>{
    l divisor=(smallestDivisor(n):Int);
    match divisor=n{
      true=>[n]|
      false=>[divisor]⧺primeFactors(n/divisor)
    }
  }
}

λsmallestDivisor(n:Int)=>Int match stdlib::list.nth(0,divisors(n)){
  Some(value)=>value|
  None()=>n
}
