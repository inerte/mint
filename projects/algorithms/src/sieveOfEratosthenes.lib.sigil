i stdlib::numeric

λfilterMultiples(prime:Int,xs:[Int])=>[Int] match xs{
  []=>[]|
  [head,.tail]=>match head%prime=0{
    true=>filterMultiples(prime,tail)|
    false=>[head]⧺filterMultiples(prime,tail)
  }
}

λsieve(limit:Int)=>[Int] match limit<2{
  true=>[]|
  false=>sieveCandidates(stdlib::numeric.range(2,limit))
}

λsieveCandidates(candidates:[Int])=>[Int] match candidates{
  []=>[]|
  [head,.tail]=>[head]⧺sieveCandidates(filterMultiples(head,tail))
}
