t IntTree=Empty()|Node([IntTree],Int)

i stdlib::list

i stdlib::numeric

λflatten(tree:IntTree)=>[Int] match tree{
  Empty()=>[]|
  Node(children,value)=>[value]⧺stdlib::list.flatMap(flatten,children)
}

λincremented(tree:IntTree)=>IntTree match tree{
  Empty()=>Empty()|
  Node(children,value)=>Node(children map incremented,value+1)
}

λpositiveValues(tree:IntTree)=>[Int]=flatten(tree) filter stdlib::numeric.isPositive

λpreorder(tree:IntTree)=>[Int]=flatten(tree)

λsumValues(tree:IntTree)=>Int=flatten(tree) reduce (λ(acc:Int,value:Int)=>Int=acc+value) from 0
