t WordBucket={count:Int,word:String}

i core::map

i stdlib::list

i stdlib::string

Î»frequency(lines:[String])=>{Stringâ†¦Int}=normalizedWords(lines) reduce increment from (core::map.empty():{Stringâ†¦Int})

Î»increment(histogram:{Stringâ†¦Int},word:String)=>{Stringâ†¦Int} match core::map.get(word,histogram){
  Some(count)=>core::map.insert(word,histogram,count+1)|
  None()=>core::map.insert(word,histogram,1)
}

Î»nonEmpty(word:String)=>Bool=wordâ‰ ""

Î»normalizedWords(lines:[String])=>[String]=stdlib::list.flatMap(splitWords,lines) filter nonEmpty

Î»splitWords(line:String)=>[String]=stdlib::string.split(" ",stdlib::string.toLower(line))

Î»summary(lines:[String])=>[WordBucket]=core::map.entries(frequency(lines)) map (Î»(entry:core::map.Entry[String,Int])=>WordBucket={count:entry.value,word:entry.key})
