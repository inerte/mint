i core::map

i src::histogram

i src::wordFrequency

λmain()=>Unit=()

test "histogram counts duplicate integers" {
  l counts=(src::histogram.histogram([1,1,2,3,3,3]):{Int↦Int});
  core::map.size(counts)=3 and (match core::map.get(3,counts){
    Some(value)=>value=3|
    None()=>false
  })
}

test "histogram buckets map entries into records" {
  #src::histogram.buckets(src::histogram.histogram([4,4,5]))=2
}

test "word frequency lowercases and counts repeated words" {
  l counts=(src::wordFrequency.frequency(["Sigil sigil map","filter reduce SIGIL"]):{String↦Int});
  match core::map.get("sigil",counts){
    Some(value)=>value=3 and core::map.size(counts)=4|
    None()=>false
  }
}

test "word frequency summary turns counts into buckets" {
  #src::wordFrequency.summary(["one two two"])=2
}
