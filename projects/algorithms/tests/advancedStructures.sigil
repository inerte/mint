i src::combinations

i src::connectedComponents

i src::graphTypes

i src::treeTraversals

λgraph()=>src::graphTypes.Graph={nodes:[{neighbors:[2],vertex:1},{neighbors:[1,3],vertex:2},{neighbors:[2],vertex:3},{neighbors:[5],vertex:4},{neighbors:[4],vertex:5}]}

λmain()=>Unit=()

λsampleTree()=>src::treeTraversals.IntTree=src::treeTraversals.Node([src::treeTraversals.Node([src::treeTraversals.Node([],-4)],2),src::treeTraversals.Node([],3)],1)

test "combinations chooses pairs in input order" {
  src::combinations.combinations(2,[1,2,3,4])=[[1,2],[1,3],[1,4],[2,3],[2,4],[3,4]]
}

test "combinations of zero is one empty combination" {
  src::combinations.combinations(0,[1,2,3])=[[]]
}

test "connected components groups disconnected subgraphs" {
  src::connectedComponents.connectedComponents(graph())=[[1,2,3],[4,5]]
}

test "tree preorder flattens node before children" {
  src::treeTraversals.preorder(sampleTree())=[1,2,-4,3]
}

test "tree incremented adds one everywhere" {
  src::treeTraversals.incremented(sampleTree())=src::treeTraversals.Node([src::treeTraversals.Node([src::treeTraversals.Node([],-3)],3),src::treeTraversals.Node([],4)],2)
}

test "tree incremented preserves empty tree" {
  src::treeTraversals.incremented(src::treeTraversals.Empty())=src::treeTraversals.Empty()
}

test "tree positive values filters negatives after flattening" {
  src::treeTraversals.positiveValues(sampleTree())=[1,2,3]
}

test "tree sum values reduces flattened tree" {
  src::treeTraversals.sumValues(sampleTree())=2
}
