i stdlib::io

i stdlib::numeric

i test::check::log

i world::log

λmain()=>Unit=()

test "log capture records side effects" =>!Log world {
  c log=(world::log.capture():world::log.LogEntry)
} {
  l _=(stdlib::io.println("captured"):Unit);
  test::check::log.contains("captured")
}

test "numeric predicates are available in projects" {
  stdlib::numeric.isEven(2)=true and stdlib::numeric.isOdd(3)=true
}

test "pure boolean passes" {
  1+1=2
}
