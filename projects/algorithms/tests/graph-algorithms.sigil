test "missing start vertex returns empty traversal" {
  srcâ‹…depth-first-search.depth_first_search(dag_graph(),99)=[] and srcâ‹…breadth-first-search.breadth_first_search(dag_graph(),99)=[]
}

test "topological sort returns ordering for dag" {
  l result=(srcâ‹…topological-sort.topological_sort(dag_graph()):srcâ‹…graph-types.TopologicalSortResult);
  match result{
