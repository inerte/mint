λmain()=>!CliIo Unit match •canonicalStdlibUsage.runCheck(){
  Ok(issues)=>match #issues=0{
    true=>{
      l _=(§io.println("Canonical stdlib usage OK"):Unit);
      §process.exit(0)
    }|
    false=>{
      l _=(§io.println("Non-canonical local stdlib helper redefinitions found:"):Unit);
      l _=(•canonicalStdlibUsage.printIssues(issues):Unit);
      §process.exit(1)
    }
  }|
  Err(message)=>{
    l _=(§io.eprintln(message):Unit);
    §process.exit(1)
  }
}
