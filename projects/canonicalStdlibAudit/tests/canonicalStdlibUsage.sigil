i src::canonicalStdlibUsage

i test::check::log

i world::log

i world::process

i stdlib::regex

i stdlib::string

λcompiledRules()=>[src::canonicalStdlibUsage.Rule]=src::canonicalStdlibUsage.rules()

λmain()=>Unit=()

test "compile rule rejects invalid regex" {
  match src::canonicalStdlibUsage.compileRule({name:"broken",pattern:"(",replacement:"stdlib::list.sum"}){
    Ok(_)=>false|
    Err(message)=>stdlib::string.indexOf(message,"broken")≥0
  }
}

test "duplicate numeric max is rejected" {
  match src::canonicalStdlibUsage.analyzeFile("projects/demo.sigil",compiledRules(),"λmax(a:Int,b:Int)=>Int=a\n"){
    [issue]=>issue.line=1 and issue.name="maxNumeric" and issue.path="projects/demo.sigil" and issue.replacement="stdlib::numeric.max"|
    _=>false
  }
}

test "duplicate reverse is rejected" {
  match src::canonicalStdlibUsage.analyzeFile("language/examples/example.sigil",compiledRules(),"λreverse[T](xs:[T])=>[T]=[]\n"){
    [issue]=>issue.line=1 and issue.name="reverseList" and issue.path="language/examples/example.sigil" and issue.replacement="stdlib::list.reverse"|
    _=>false
  }
}

test "duplicate string take is rejected" {
  match src::canonicalStdlibUsage.analyzeFile("projects/demo.sigil",compiledRules(),"λtake(n:Int,s:String)=>String=s\n"){
    [issue]=>issue.line=1 and issue.name="takeString" and issue.path="projects/demo.sigil" and issue.replacement="stdlib::string.take"|
    _=>false
  }
}

test "duplicate sum is rejected" {
  match src::canonicalStdlibUsage.analyzeFile("language/examples/example.sigil",compiledRules(),"λsum(xs:[Int])=>Int=0\n"){
    [issue]=>issue.line=1 and issue.name="sum" and issue.path="language/examples/example.sigil" and issue.replacement="stdlib::list.sum"|
    _=>false
  }
}

test "parse tracked files rejects failed git output" {
  match src::canonicalStdlibUsage.parseTrackedFiles({code:1,stderr:"boom",stdout:""}){
    Ok(_)=>false|
    Err(message)=>message="git ls-files failed: boom"
  }
}

test "git tracked files surfaces git failure" =>!Process world {
  c process=(world::process.fixture([world::process.rule(["git","ls-files","*.sigil","*.lib.sigil"],None(),{code:1,stderr:"boom",stdout:""})]):world::process.ProcessEntry)
} {
  match src::canonicalStdlibUsage.gitTrackedFiles(){
    Ok(_)=>false|
    Err(message)=>message="git ls-files failed: boom"
  }
}

test "print issues writes formatted log line" =>!Log world {
  c log=(world::log.capture():world::log.LogEntry)
} {
  l _=(src::canonicalStdlibUsage.printIssues([{line:7,name:"sum",path:"projects/demo.sigil",replacement:"stdlib::list.sum"}]):Unit);
  test::check::log.contains("projects/demo.sigil:7: local 'sum' duplicates canonical helper 'stdlib::list.sum'; use the qualified stdlib path instead.")
}

test "run check surfaces git top level failure" =>!AuditIo world {
  c process=(world::process.fixture([world::process.rule(["git","rev-parse","--show-toplevel"],None(),{code:1,stderr:"boom",stdout:""})]):world::process.ProcessEntry)
} {
  match src::canonicalStdlibUsage.runCheck(){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  }
}

test "run check finds no canonical stdlib duplicates in repo" =>!AuditIo {
  match src::canonicalStdlibUsage.runCheck(){
    Ok(issues)=>issues=[]|
    Err(_)=>false
  }
}

test "same name with different shape is allowed" {
  src::canonicalStdlibUsage.analyzeFile("language/test-fixtures/example.sigil",compiledRules(),"λsum(acc:Int,x:Int)=>Int=acc+x\n")=[]
}

test "stdlib path is ignored" {
  src::canonicalStdlibUsage.ignorePath("language/stdlib/list.lib.sigil")
}
