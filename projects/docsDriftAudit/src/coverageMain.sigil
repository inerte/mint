λmain()=>!CliIo Unit match •docsDrift.runCoverageOnly(){
  Ok(issues)=>match #issues=0{
    true=>{
      l _=(§io.println("Docs/example drift coverage OK"):Unit);
      §process.exit(0)
    }|
    false=>{
      l _=(§io.println("Docs/example drift coverage issues found:"):Unit);
      l _=(•docsDrift.printIssues(issues):Unit);
      §process.exit(1)
    }
  }|
  Err(message)=>{
    l _=(§io.eprintln(message):Unit);
    §process.exit(1)
  }
}
