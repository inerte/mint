test "fence helpers parse valid and invalid forms" {
  l extracted=(src::fences.extractSnippets("docs/test.md",stdlib::string.unlines(["```sigil module src/sample.lib.sigil","λsample()=>String=\"ok\"","```"])):src::types.ExtractResult);
  allOk([match src::fences.parseFenceInfo("sigil module src/sample.lib.sigil"){
    Ok(info)=>{
      l parsed=(info:src::types.FenceInfo);
      parsed.kind="module" and (match parsed.context{
        Some(path)=>path="src/sample.lib.sigil"|
        None()=>false
      })
    }|
    Err(_)=>false
  },match src::fences.parseFenceInfo("sigil unknown"){
    Ok(_)=>false|
    Err(message)=>stdlib::string.indexOf(message,"unknown Sigil fence kind")≥0
  },match src::fences.parseFenceKind("module src/sample.lib.sigil"){
    Ok(info)=>{
      l parsed=(info:src::types.FenceInfo);
      parsed.kind="module" and (match parsed.context{
        Some(path)=>path="src/sample.lib.sigil"|
        None()=>false
      })
    }|
    Err(_)=>false
  },match src::fences.parseFenceKindWithContext("module","src/sample.lib.sigil"){
    Ok(info)=>{
      l parsed=(info:src::types.FenceInfo);
      parsed.kind="module" and (match parsed.context{
        Some(path)=>path="src/sample.lib.sigil"|
        None()=>false
      })
    }|
    Err(_)=>false
  },match src::fences.parseFenceKindWithContext("expr","arg"){
    Ok(_)=>false|
    Err(message)=>stdlib::string.indexOf(message,"does not accept an argument")≥0
  },match src::fences.parseFenceKindWithoutContext("expr"){
    Ok(info)=>{
      l parsed=(info:src::types.FenceInfo);
      parsed.kind="expr" and (match parsed.context{
        None()=>true|
        Some(_)=>false
      })
    }|
    Err(_)=>false
  },match src::fences.parseFenceKindWithoutContext("mystery"){
    Ok(_)=>false|
    Err(message)=>stdlib::string.indexOf(message,"unknown Sigil fence kind")≥0
  },match src::fences.parseModulePath("module","src/sample.lib.sigil"){
    Ok(info)=>{
      l parsed=(info:src::types.FenceInfo);
      parsed.kind="module" and (match parsed.context{
        Some(path)=>path="src/sample.lib.sigil"|
        None()=>false
      })
    }|
    Err(_)=>false
  },match src::fences.parseModulePath("module","src/sample.sigil"){
    Ok(_)=>false|
    Err(message)=>stdlib::string.indexOf(message,"must use a .lib.sigil virtual path")≥0
  },match src::fences.parseProgramPath("program","src/sample.lib.sigil"){
    Ok(_)=>false|
    Err(message)=>stdlib::string.indexOf(message,"must use a .sigil virtual path")≥0
  },match src::fences.parseProgramPath("program","src/sample.sigil"){
    Ok(info)=>{
      l parsed=(info:src::types.FenceInfo);
      parsed.kind="program" and (match parsed.context{
        Some(path)=>path="src/sample.sigil"|
        None()=>false
      })
    }|
    Err(_)=>false
  },src::fences.invalidFenceIssue("docs/test.md",2,"boom")={line:2,message:"boom",path:"docs/test.md"},src::fences.isFence("```"),src::fences.isSigilFence("```sigil expr"),src::fences.nonEmpty("x"),extracted.issues=[],match extracted.results{
    [item]=>{
      l found=(item:src::types.Snippet);
      found.info.kind="module" and found.line=1
    }|
    _=>false
  }])
}

test "markdown coverage helpers read sandbox files" =>!Fs world {
  c fs=(world::fs.sandbox(".local/docsDriftAuditCoverage/markdownSandbox"):world::fs.FsEntry)
} {
  l _=(stdlib::file.makeDirs("docs"):Unit);
  l _=(stdlib::file.makeDirs("tests"):Unit);
  l _=(stdlib::file.writeText(stdlib::string.unlines(["```sigil decl stdlib::string","λtrim(s:String)=>String","```","","```sigil expr","stdlib::string.trim(\" hi \")","```"]),"docs/example.md"):Unit);
  l _=(stdlib::file.writeText("λmain()=>Unit={\n  l sample=(stdlib::string.trim(\" hi \"):String);\n  ()\n}\n","tests/example.sigil"):Unit);
  l audit=(src::docsDrift.collectMarkdownAuditRefs("docs/example.md","."):src::docsDrift.MarkdownAudit);
  l coverageAudit=(src::docsDrift.runMarkdownCoverageAudit(["docs/example.md"],"."):src::docsDrift.MarkdownAudit);
  l refs=(src::docsDrift.readCoverageRefs(["tests/example.sigil"],"."):[String]);
  allOk([audit.documentedRefs=["stdlib::string.trim"],audit.issues=[],audit.snippetRefs=["stdlib::string.trim"],coverageAudit.documentedRefs=["stdlib::string.trim"],coverageAudit.issues=[],coverageAudit.snippetRefs=["stdlib::string.trim"],refs=["stdlib::string.trim"]])
}

test "path based helpers succeed on decl only markdown" =>!AuditIo {
  l root=(repoRoot():String);
  l path=(".local/docsDriftAuditCoverage/declOnly.md":String);
  l tempDir=(stdlib::path.join(root,".local/docsDriftAuditCoverage/tmp-decl"):String);
  l _=(stdlib::file.makeDirs(".local/docsDriftAuditCoverage"):Unit);
  l _=(stdlib::file.removeTree(tempDir):Unit);
  l _=(stdlib::file.makeDirs(tempDir):Unit);
  l _=(stdlib::file.writeText(stdlib::string.unlines(["```sigil decl stdlib::string","λtrim(s:String)=>String","```"]),path):Unit);
  l markdownAudit=(src::docsDrift.processMarkdownFile(false,path,root,tempDir):src::docsDrift.MarkdownAudit);
  l refsForFile=(src::docsDrift.runRefsForFile(path):Result[src::docsDrift.MarkdownAudit,String]);
  l refsForPaths=(src::docsDrift.runRefsForPaths([path]):Result[src::docsDrift.MarkdownAudit,String]);
  l runCheck=(src::docsDrift.runCheckForPaths([path]):Result[[src::types.Issue],String]);
  allOk([markdownAudit.issues=[],match refsForFile{
    Ok(audit)=>{
      l found=(audit:src::docsDrift.MarkdownAudit);
      found.documentedRefs=["stdlib::string.trim"] and found.issues=[]
    }|
    Err(_)=>false
  },match refsForPaths{
    Ok(audit)=>{
      l found=(audit:src::docsDrift.MarkdownAudit);
      found.documentedRefs=["stdlib::string.trim"] and found.issues=[]
    }|
    Err(_)=>false
  },match runCheck{
    Ok(issues)=>issues=[]|
    Err(_)=>false
  }])
}

