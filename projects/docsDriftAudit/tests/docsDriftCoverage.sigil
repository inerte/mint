test "stdlib export helpers parse repo stdlib files" =>!AuditIo {
  l root=(repoRoot():String);
  l readExports=(src::docsDrift.readStdlibExports(["language/stdlib/string.lib.sigil"],root):Result[[String],String]);
  l readExportsInner=(src::docsDrift.readStdlibExportsInner([],["language/stdlib/string.lib.sigil"],root):Result[[String],String]);
  l readMissing=(src::docsDrift.readStdlibExports(["language/stdlib/missing.lib.sigil"],root):Result[[String],String]);
  l fileExports=(src::docsDrift.runStdlibExportsForFile("language/stdlib/string.lib.sigil"):Result[[String],String]);
  l pathExports=(src::docsDrift.runStdlibExportsForPaths(["language/stdlib/string.lib.sigil"]):Result[[String],String]);
  l pathExportsInner=(src::docsDrift.runStdlibExportsForPathsInner([],["language/stdlib/string.lib.sigil"],root):[String]);
  allOk([match readExports{
    Ok(exports)=>stdlib::list.contains("stdlib::string.trim",exports)|
    Err(_)=>false
  },match readExportsInner{
    Ok(exports)=>stdlib::list.contains("stdlib::string.trim",exports)|
    Err(_)=>false
  },match readMissing{
    Ok(_)=>false|
    Err(message)=>stdlib::string.indexOf(message,"sigil parse failed")≥0
  },match fileExports{
    Ok(exports)=>stdlib::list.contains("stdlib::string.trim",exports)|
    Err(_)=>false
  },match pathExports{
    Ok(exports)=>stdlib::list.contains("stdlib::string.trim",exports)|
    Err(_)=>false
  },stdlib::list.contains("stdlib::string.trim",pathExportsInner)])
}

test "git discovery helpers return repo paths" =>!Process {
  l markdown=(src::docsDrift.gitTrackedMarkdown():Result[[String],String]);
  l selection=(src::docsDrift.selectedMarkdownPaths():Result[src::docsDrift.MarkdownSelection,String]);
  l stdlibPaths=(src::docsDrift.gitTrackedStdlib():Result[[String],String]);
  l stdlibTests=(src::docsDrift.gitTrackedStdlibTests():Result[[String],String]);
  allOk([match markdown{
    Ok(paths)=>#paths>0|
    Err(_)=>false
  },match selection{
    Ok(found)=>{
      l selectedPaths=(found:src::docsDrift.MarkdownSelection);
      ¬selectedPaths.failFast and #selectedPaths.paths>0
    }|
    Err(_)=>false
  },match stdlibPaths{
    Ok(paths)=>#paths>0|
    Err(_)=>false
  },match stdlibTests{
    Ok(paths)=>#paths>0|
    Err(_)=>false
  }])
}

test "git rev parse failure propagates through wrappers" =>!AuditIo world {
  c process=(world::process.fixture([world::process.rule(["git","rev-parse","--show-toplevel"],None(),{code:1,stderr:"boom",stdout:""})]):world::process.ProcessEntry)
} {
  allOk([match src::docsDrift.gitTopLevel(){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  },match src::docsDrift.runCheck(){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  },match src::docsDrift.runCheckForPaths(["docs/test.md"]){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  },match src::docsDrift.runCoverageOnly(){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  },match src::docsDrift.runRefsForFile("docs/test.md"){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  },match src::docsDrift.runRefsForPaths(["docs/test.md"]){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  },match src::docsDrift.runRepoCheck(){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  },match src::docsDrift.runStdlibExportsForFile("language/stdlib/string.lib.sigil"){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  },match src::docsDrift.runStdlibExportsForPaths(["language/stdlib/string.lib.sigil"]){
    Ok(_)=>false|
    Err(message)=>message="git rev-parse failed: boom"
  }])
}

