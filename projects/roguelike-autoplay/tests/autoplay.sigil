  match •roguelike.targetPlayerMelee(•roguelike.playerActor(5,1,•roguelike.point(4,4)),•roguelike.withLoadout(•roguelike.loadoutWithMelee(•roguelike.defaultLoadout(),µSpear()),•roguelike.demoStateWithInventory([•roguelike.playerActor(5,1,•roguelike.point(4,4)),•roguelike.goblinActor(2,2,•roguelike.point(4,6))],0,0,•roguelike.point(35,12),([]:[µPickup]),0))){
    Some(target)=>target.id=2|
    None()=>false
  }
}

