λmain()=>Unit=()

test "bestStepToward returns none from a blocked wall position" {
  match •roguelike.bestStepToward(1,false,•roguelike.point(0,0),•roguelike.demoState([•roguelike.playerActor(5,1,•roguelike.point(0,0))],•roguelike.point(35,12),([]:[µPickup]),0),•roguelike.point(1,1)){
    None()=>true|
    Some(_)=>false
  }
}

test "collectPickup adds potion inventory and clears tile" {
  l next=(•roguelike.collectPickup(•roguelike.point(4,4),•roguelike.demoStateWithInventory([•roguelike.playerActor(5,1,•roguelike.point(6,4))],0,0,•roguelike.point(35,12),[•roguelike.potionPickup(•roguelike.point(4,4))],0)):µGameState);
  next.loadout.potions=1 and next.collectedTreasure=0 and #next.pickups=0
}

test "collectPickup adds treasure score and clears tile" {
  l next=(•roguelike.collectPickup(•roguelike.point(4,4),•roguelike.demoStateWithInventory([•roguelike.playerActor(5,1,•roguelike.point(6,4))],0,0,•roguelike.point(35,12),[•roguelike.treasurePickup(•roguelike.point(4,4))],0)):µGameState);
  next.loadout.potions=0 and next.collectedTreasure=1 and #next.pickups=0
}

test "collectPickup equips the spear pickup" {
  l next=(•roguelike.collectPickup(•roguelike.point(4,4),•roguelike.demoStateWithInventory([•roguelike.playerActor(5,1,•roguelike.point(6,4))],0,0,•roguelike.point(35,12),[•roguelike.spearPickup(•roguelike.point(4,4))],0)):µGameState);
  next.loadout.melee=µSpear() and #next.pickups=0
}

