test "throwBombApply removes enemies in the blast" {
  l next=(•roguelike.throwBombApply([•roguelike.playerActor(5,1,•roguelike.point(2,2)),•roguelike.goblinActor(2,2,•roguelike.point(5,5)),•roguelike.archerActor(2,3,•roguelike.point(6,5))],•roguelike.point(5,5),•roguelike.demoStateWithInventory([•roguelike.playerActor(5,1,•roguelike.point(2,2)),•roguelike.goblinActor(2,2,•roguelike.point(5,5)),•roguelike.archerActor(2,3,•roguelike.point(6,5))],0,0,•roguelike.point(35,12),([]:[µPickup]),0)):µGameState);
  match •roguelike.findActorById(2,next.actors){
    Some(_)=>false|
    None()=>match •roguelike.findActorById(3,next.actors){
      Some(_)=>false|
      None()=>true
    }
  }
}

