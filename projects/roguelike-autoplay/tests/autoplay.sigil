test "generated game has five rooms and five pickups" =>!Random world {
  c random=(†random.seeded(1337):†random.RandomEntry)
} {
  l state=(•roguelike.makeGame():µGameState);
  #state.pickups=5 and #state.rooms=5
}

test "rendered frame contains player enemies exit and pickup glyphs" {
  l map=(•roguelike.renderFrame(•roguelike.demoStateWithInventory([•roguelike.playerActor(5,1,•roguelike.point(4,4)),•roguelike.goblinActor(2,2,•roguelike.point(20,4)),•roguelike.archerActor(2,3,•roguelike.point(21,4)),•roguelike.bruteActor(4,4,•roguelike.point(22,4)),•roguelike.shamanActor(2,5,•roguelike.point(23,4))],0,0,•roguelike.point(35,12),[•roguelike.potionPickup(•roguelike.point(24,4)),•roguelike.bombPickup(•roguelike.point(25,4)),•roguelike.blinkPickup(•roguelike.point(26,4)),•roguelike.spearPickup(•roguelike.point(27,4)),•roguelike.treasurePickup(•roguelike.point(28,4))],0)).map:String);
  §string.indexOf(map,"@")≥0 and §string.indexOf(map,"g")≥0 and (§string.indexOf(map,"a")≥0 and §string.indexOf(map,"B")≥0) and (§string.indexOf(map,"s")≥0 and §string.indexOf(map,">")≥0 and (§string.indexOf(map,"!")≥0 and §string.indexOf(map,"*")≥0 and (§string.indexOf(map,"?")≥0 and §string.indexOf(map,"/")≥0 and §string.indexOf(map,"$")≥0)))
}

test "stepPlayer drinks a potion at low hp" {
  l next=(•roguelike.stepPlayer(•roguelike.demoStateWithInventory([•roguelike.playerActor(2,1,•roguelike.point(4,4))],1,0,•roguelike.point(35,12),([]:[µPickup]),0)):µGameState);
  next.lastAction="drink potion" and next.loadout.potions=0 and •roguelike.playerHp(next)=4
}

test "stepPlayer shoots the bow at a visible enemy" {
  l next=(•roguelike.stepPlayer(•roguelike.demoStateWithInventory([•roguelike.playerActor(5,1,•roguelike.point(4,4)),•roguelike.archerActor(2,2,•roguelike.point(8,4))],0,0,•roguelike.point(35,12),([]:[µPickup]),0)):µGameState);
  next.lastAction="shoot bow" and next.loadout.arrows=5 and (match •roguelike.findActorById(2,next.actors){
    Some(actor)=>actor.hp=1|
    None()=>false
  })
}

