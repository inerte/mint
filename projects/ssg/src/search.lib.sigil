О»allPages(data:вҖўtypes.SiteData)=>[вҖўtypes.SitePage]=[data.home,data.articlesIntro]в§әdata.articlesв§әdata.docsв§әdata.specв§әdata.standalone

О»pageText(page:вҖўtypes.SitePage)=>String=В§string.trim(page.bodyMarkdown)

О»pageValue(page:вҖўtypes.SitePage)=>В§json.JsonValue=В§json.JsonObject({"description"вҶҰВ§json.JsonString(page.meta.description),"section"вҶҰВ§json.JsonString(вҖўcontent.sectionNameLowercase(page.section)),"sourcePath"вҶҰВ§json.JsonString(page.sourcePath),"text"вҶҰВ§json.JsonString(pageText(page)),"title"вҶҰВ§json.JsonString(page.meta.title),"url"вҶҰВ§json.JsonString(вҖўcontent.canonicalRoute(page))})

О»pagesValue(pages:[вҖўtypes.SitePage])=>В§json.JsonValue=В§json.JsonArray(pages map pageValue)

О»searchIndexJson(data:вҖўtypes.SiteData)=>String=В§json.stringify(pagesValue(allPages(data)))
