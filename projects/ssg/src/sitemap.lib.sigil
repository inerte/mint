λabsoluteUrl(config:•types.SiteBuildConfig,page:•types.SitePage)=>String=trimTrailingSlash(config.siteUrl)++•content.canonicalRoute(page)

λallPages(data:•types.SiteData)=>[•types.SitePage]=[data.home,data.articlesIntro]⧺data.articles⧺data.docs⧺data.spec⧺data.standalone

λpageEntries(config:•types.SiteBuildConfig,pages:[•types.SitePage])=>String=§string.join("",pages map (λ(page:•types.SitePage)=>String=pageEntry(config,page)))

λpageEntry(config:•types.SiteBuildConfig,page:•types.SitePage)=>String="<url><loc>"++absoluteUrl(config,page)++"</loc>"++pageLastMod(page)++"</url>"

λpageLastMod(page:•types.SitePage)=>String match #page.meta.date>0{
  true=>"<lastmod>"++page.meta.date++"</lastmod>"|
  false=>""
}

λsitemapXml(config:•types.SiteBuildConfig,data:•types.SiteData)=>String="<?xml version=\"1.0\" encoding=\"UTF-8\"?>"++"<urlset xmlns=\"http://www.sitemaps.org/schemas/sitemap/0.9\">"++pageEntries(config,allPages(data))++"</urlset>"

λtrimTrailingSlash(path:String)=>String match #path>1 and §string.endsWith(path,"/"){
  true=>trimTrailingSlash(§string.substring(#path-1,path,0))|
  false=>path
}
