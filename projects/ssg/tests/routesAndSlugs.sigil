λdocPage(slug:String)=>µSitePage=•content.blankPage("",{author:"",category:"",date:"",description:"",slug:slug,title:slug},"docs/"++slug,µDoc(),"language/docs/"++slug++".md")

λhomePage()=>µSitePage=•content.blankPage("",{author:"",category:"",date:"",description:"",slug:"home",title:"Home"},"",µHome(),"website/README.md")

λmain()=>Unit=()

test "article route uses section slug" {
  •content.canonicalRoute((•content.blankPage("",{author:"",category:"",date:"",description:"",slug:"hello-world",title:"Hello World"},"articles/hello-world",µArticle(),"website/articles/hello-world.md"):µSitePage))="/articles/hello-world/"
}

test "docs sort uses canonical slug order" {
  l sorted=(•content.pagesSortedByTitle(([docPage("stdlib"),docPage("async")]:[µSitePage])):[µSitePage]);
  sorted[0].meta.slug="async" and sorted[1].meta.slug="stdlib"
}

test "home route is canonical root" {
  •content.canonicalRoute(homePage())="/"
}
