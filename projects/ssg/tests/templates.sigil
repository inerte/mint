i src::content

i src::templates

i src::types

i stdlib::string

λconfig()=>src::types.SiteBuildConfig={basePath:"/",outputDir:".local/site",repoUrl:"https://github.com/inerte/sigil",siteDescription:"Machine-first programming language designed for canonical code generation.",siteTitle:"Sigil",siteUrl:"https://inerte.github.io/sigil"}

λcontains(haystack:String,needle:String)=>Bool=stdlib::string.indexOf(haystack,needle)≥0

λdocPage(slug:String)=>src::types.SitePage=src::content.blankPage("",{author:"",category:"",date:"2026-03-23",description:"Reference page",slug:slug,title:"Docs "++slug},"docs/"++slug,src::types.Doc(),"language/docs/"++slug++".md")

λmain()=>Unit=()

λspecPage(slug:String)=>src::types.SitePage=src::content.blankPage("",{author:"",category:"",date:"2026-03-23",description:"Spec page",slug:slug,title:"Spec "++slug},"spec/"++slug,src::types.Spec(),"language/spec/"++slug++".md")

test "reference list renders heading and first pages" {
  l html=(src::templates.referenceList(config(),"Docs",[docPage("stdlib"),docPage("testing")]):String);
  contains(html,"<h2>Docs</h2>") and contains(html,"Docs stdlib") and contains(html,"Docs testing")
}

test "reference lists render docs and spec sections" {
  l html=(src::templates.referenceLists(config(),[docPage("stdlib")],[specPage("grammar")]):String);
  contains(html,"<h2>Docs</h2>") and contains(html,"<h2>Spec</h2>") and contains(html,"Spec grammar")
}

test "section card renders heading route and call to action" {
  l html=(src::templates.sectionCard("Reference docs rendered directly from the repo.",config(),"Read docs","Docs","/docs/"):String);
  contains(html,"<h2>Docs</h2>") and contains(html,"href=\"/docs/\"") and contains(html,">Read docs<")
}
