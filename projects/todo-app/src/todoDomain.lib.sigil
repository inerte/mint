t Todo={done:Bool,id:Int,text:String}

λaddTodo(id:Int,text:String,todos:[Todo])=>[Todo]=[{done:false,id:id,text:text}]⧺todos

λcanAdd(text:String)=>Bool=text≠""

λclearCompleted(todos:[Todo])=>[Todo]=todos filter (λ(todo:Todo)=>Bool=¬todo.done)

λcompletedCount(todos:[Todo])=>Int=todos reduce (λ(acc:Int,todo:Todo)=>Int match todo.done{
  true=>acc+1|
  false=>acc
}) from 0

λdeleteTodo(targetId:Int,todos:[Todo])=>[Todo]=todos filter (λ(todo:Todo)=>Bool=todo.id≠targetId)

λeditTodo(newText:String,targetId:Int,todos:[Todo])=>[Todo]=todos map (λ(todo:Todo)=>Todo match todo.id=targetId{
  true=>{done:todo.done,id:todo.id,text:newText}|
  false=>todo
})

λisVisible(done:Bool,filter:String)=>Bool match filter{
  "all"=>true|
  "active"=>¬done|
  "completed"=>done|
  _=>true
}

λremainingCount(completed:Int,total:Int)=>Int=total-completed

λtoggleTodo(targetId:Int,todos:[Todo])=>[Todo]=todos map (λ(todo:Todo)=>Todo match todo.id=targetId{
  true=>{done:¬todo.done,id:todo.id,text:todo.text}|
  false=>todo
})
