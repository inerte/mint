i src::todoJson

i src::todoDomain

i stdlib::json

λmain()=>Unit=()

test "todo json decode rejects invalid payload" {
  match src::todoJson.decodeState("{bad"){
    Ok(_)=>false|
    Err(_)=>true
  }
}

test "todo json decode rejects missing fields" {
  match src::todoJson.decodeState("{\"todos\":[]}"){
    Ok(_)=>false|
    Err(_)=>true
  }
}

test "todo json decode next todo id rejects non numeric string" {
  match src::todoJson.decodeNextTodoId((stdlib::json.JsonString("oops"):stdlib::json.JsonValue)){
    Ok(_)=>false|
    Err(_)=>true
  }
}

test "todo json decode todo rejects missing text field" {
  match src::todoJson.decodeTodo((stdlib::json.JsonObject({"done"↦stdlib::json.JsonBool(false),"id"↦stdlib::json.JsonString("1")}):stdlib::json.JsonValue)){
    Ok(_)=>false|
    Err(_)=>true
  }
}

test "todo json roundtrip preserves state" {
  l state=({nextId:src::todoJson.NextTodoId(9),todos:[{done:false,id:1,text:"Ship JSON stdlib"},{done:true,id:2,text:"Write tests"}]}:src::todoJson.PersistedState);
  match src::todoJson.decodeState((src::todoJson.encodeState(state):String)){
    Ok(decoded)=>decoded=state|
    Err(_)=>false
  }
}

test "todo json decode accepts numeric ids from older payloads" {
  match src::todoJson.decodeState("{\"nextId\":9,\"todos\":[{\"done\":false,\"id\":1,\"text\":\"Ship JSON stdlib\"}]}"){
    Ok(state)=>src::todoJson.nextTodoIdValue(state.nextId)=9 and #state.todos=1 and state.todos[0].id=1|
    Err(_)=>false
  }
}
